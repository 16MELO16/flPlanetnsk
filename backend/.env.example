# Для запуска backend отдельно от docker compose.
# При запуске через корневой docker-compose.yml эти значения прокидываются автоматически.

DB_HOST=db
DB_PORT=5432
DB_NAME=flower
DB_USER=flower
DB_PASSWORD=change_me_strong_password

# Если удобнее одной строкой, можно использовать DATABASE_URL.
# Он имеет приоритет над DB_HOST/DB_PORT/DB_NAME/DB_USER/DB_PASSWORD.
# DATABASE_URL=postgresql+psycopg://flower:change_me_strong_password@db:5432/flower
